{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Using": [ "Serilog.Exceptions", "Serilog.Enrichers.Sensitive", "Serilog.Sinks.OpenTelemetry" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "http://localhost:4317",
          "protocol": "Grpc",
          "resourceAttributes": {
            "service.name": "ObservabilityLab.Api"
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithEnvironmentName",
      "WithProcessId",
      "WithExceptionDetails",
      {
        "Name": "WithSensitiveDataMasking",
        "Args": {
          "maskingRules": [
            {
              "pattern": "(?i)(\"?password\"?\\s*:\\s*\")[^\"]+(\")",
              "replacement": "***REDACTED***"
            },
            {
              "pattern": "(?i)(\"?authorization\"?\\s*:\\s*\")[^\"]+(\")",
              "replacement": "***REDACTED***"
            },
            {
              "pattern": "(?i)(\"?apiKey\"?\\s*:\\s*\")[^\"]+(\")",
              "replacement": "***REDACTED***"
            },
            {
              "pattern": "(?i)(\"?email\"?\\s*:\\s*\")[^\"]+(\")",
              "replacement": "***REDACTED***"
            }
          ]
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=5432;Database=ObservabilityLab;User Id=postgres;Password=postgres"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "observability",
    "Password": "observability",
    "VirtualHost": "/"
  }
}
